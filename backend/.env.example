APP_NAME=vocalis.io
ENVIRONMENT=development
DEBUG=false

HOST=0.0.0.0
PORT=8000

LOG_LEVEL=INFO

CORS_ALLOWED_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000", "http://127.0.0.1:3000", "http://localhost:3010", "http://127.0.0.1:3010"]

DATABASE_URL="Enter Your Database URL Here"
JWT_SECRET_KEY="Enter Your JWT Secret Key Here"

HUGGINGFACE_MODEL_ID=matheetharanadshyan/wav2vec2-svarah
HUGGINGFACE_CACHE_DIR=.cache/huggingface
HUGGINGFACE_TOKEN="Enter Your Hugging Face Token Here"

USE_GROQ=false
GROQ_API_KEY="Enter Your Groq API Key Here"
GROQ_MODEL=llama-4-scout-17b-16e-instruct

DEVICE=cpu
ALIGNMENT_QUANTIZATION_BACKEND=none

SAMPLE_RATE=16000
MIN_AUDIO_DURATION_SECONDS=0.5
MAX_AUDIO_DURATION_SECONDS=30.0

MAX_WEBSOCKET_BUFFER_MB=10
REALTIME_INFERENCE_TIMEOUT_SECONDS=20.0
MAX_CONCURRENT_REALTIME_INFERENCES=4

SENTRY_DSN="Enter Your Sentry DSN Here"

BACKUP_ENABLED=true
BACKUP_DIRECTORY=backups
BACKUP_RETENTION_DAYS=30
