{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev --turbopack",
    "build": "bun --bun next build --turbopack",
    "start": "bun --bun next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "contracts": "cd ../backend && .venv/bin/python scripts/export_openapi.py --output ../frontend/lib/generated/openapi.json && .venv/bin/python scripts/export_openapi_types.py --input ../frontend/lib/generated/openapi.json --output ../frontend/lib/generated/api-types.ts",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@sentry/nextjs": "^10",
    "ai": "^6.0.194",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "media-chrome": "^4.19.1",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "qr-code-styling": "^1.9.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "prettier": "3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
